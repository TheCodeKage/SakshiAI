<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for SaakshiAI
   Excludes encrypted database from Android backups for security.
-->
<full-backup-content>
    <!-- Exclude encrypted incident database -->
    <exclude domain="database" path="saakshi.db" />
    <exclude domain="database" path="saakshi.db-shm" />
    <exclude domain="database" path="saakshi.db-wal" />
</full-backup-content>